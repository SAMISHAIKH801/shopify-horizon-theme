  <div class="marine-header-modal-{{ ai_gen_id }}" data-engine-modal-container>
    <div class="marine-header-modal-content-{{ ai_gen_id }}">
      <button class="marine-header-modal-close-{{ ai_gen_id }}" data-modal-close>&times;</button>
      <div class="marine-header-modal-body-{{ ai_gen_id }}">
        <div class="marine-header-modal-left-{{ ai_gen_id }}">
          {% if block.settings.engine_modal_image %}
            <img src="{{ block.settings.engine_modal_image | image_url: width: 500 }}" alt="Shop by Engine">
