  <div class="marine-header-drawer-{{ ai_gen_id }} right" data-cart-drawer-container>
    <div class="marine-header-drawer-header-{{ ai_gen_id }}">
      <h3 style="margin: 0; color: {{ block.settings.drawer_text_color }};">Cart</h3>
      <button class="marine-header-drawer-close-{{ ai_gen_id }}" data-cart-close>&times;</button>
    </div>
    <div class="marine-header-drawer-body-{{ ai_gen_id }}" data-cart-items>
      {% if cart.item_count > 0 %}
        {% for item in cart.items %}
          <div class="marine-header-cart-item-{{ ai_gen_id }}">
            <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title }}" class="marine-header-cart-item-img-{{ ai_gen_id }}">
            <div class="marine-header-cart-item-info-{{ ai_gen_id }}">
              <div class="marine-header-cart-item-title-{{ ai_gen_id }}">{{ item.product.title }}</div>
              <div class="marine-header-cart-item-price-{{ ai_gen_id }}">{{ item.final_line_price | money }}</div>
              <div class="marine-header-cart-qty-{{ ai_gen_id }}">
                <button class="marine-header-cart-qty-btn-{{ ai_gen_id }}" data-qty-change="{{ item.key }}" data-qty="{{ item.quantity | minus: 1 }}">-</button>
                <input type="number" value="{{ item.quantity }}" class="marine-header-cart-qty-input-{{ ai_gen_id }}" readonly>
                <button class="marine-header-cart-qty-btn-{{ ai_gen_id }}" data-qty-change="{{ item.key }}" data-qty="{{ item.quantity | plus: 1 }}">+</button>
              </div>
            </div>
          </div>
        {% endfor %}
      {% else %}
        <p style="text-align: center; padding: 40px 20px; color: {{ block.settings.drawer_text_color }};">Your cart is empty</p>
      {% endif %}
    </div>
    {% if cart.item_count > 0 %}
      <div class="marine-header-cart-footer-{{ ai_gen_id }}">
        <div class="marine-header-cart-subtotal-{{ ai_gen_id }}">
          <span>Subtotal</span>
          <span data-cart-total>{{ cart.total_price | money }}</span>
        </div>
        <button class="marine-header-cart-checkout-btn-{{ ai_gen_id }}" onclick="window.location.href='/checkout'">Checkout</button>
        <a href="/cart" class="marine-header-cart-view-link-{{ ai_gen_id }}">View Cart</a>
      </div>
    {% endif %}
  </div>
</marine-header-{{ ai_gen_id }}>

<script>
  (function() {
    class MarineHeader{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.engineModalBtn = this.querySelectorAll('[data-engine-modal]');
        this.engineModal = this.querySelector('[data-engine-modal-container]');
        this.modalClose = this.querySelector('[data-modal-close]');
        this.menuDrawerBtn = this.querySelector('[data-menu-drawer]');
        this.menuDrawer = this.querySelector('[data-menu-drawer-container]');
        this.cartDrawerBtn = this.querySelectorAll('[data-cart-drawer]');
        this.cartDrawer = this.querySelector('[data-cart-drawer-container]');
        this.drawerOverlay = this.querySelector('[data-drawer-overlay]');
        this.drawerCloseBtns = this.querySelectorAll('[data-drawer-close]');
        this.cartCloseBtn = this.querySelector('[data-cart-close]');
        this.parentLinks = this.querySelectorAll('[data-parent-link]');
        this.backBtns = this.querySelectorAll('[data-back-btn]');
        this.qtyChangeBtns = this.querySelectorAll('[data-qty-change]');
      }

      connectedCallback() {
        this.engineModalBtn.forEach(btn => {
          btn.addEventListener('click', () => this.openEngineModal());
        });

        if (this.modalClose) {
          this.modalClose.addEventListener('click', () => this.closeEngineModal());
        }

        if (this.engineModal) {
          this.engineModal.addEventListener('click', (e) => {
            if (e.target === this.engineModal) {
              this.closeEngineModal();
            }
          });
        }

        if (this.menuDrawerBtn) {
          this.menuDrawerBtn.addEventListener('click', () => this.openMenuDrawer());
        }

        this.cartDrawerBtn.forEach(btn => {
          btn.addEventListener('click', () => this.openCartDrawer());
        });

        this.drawerCloseBtns.forEach(btn => {
          btn.addEventListener('click', () => this.closeDrawers());
        });

        if (this.cartCloseBtn) {
          this.cartCloseBtn.addEventListener('click', () => this.closeDrawers());
        }

        if (this.drawerOverlay) {
          this.drawerOverlay.addEventListener('click', () => this.closeDrawers());
        }

        this.parentLinks.forEach(link => {
          link.addEventListener('click', (e) => {
            e.preventDefault();
            const index = link.getAttribute('data-parent-link');
            const submenu = this.querySelector(`[data-submenu="${index}"]`);
            if (submenu) {
              submenu.classList.add('active');
            }
          });
        });

        this.backBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            const submenu = btn.closest('.marine-header-mobile-submenu-{{ ai_gen_id }}');
            if (submenu) {
              submenu.classList.remove('active');
            }
          });
        });

        this.qtyChangeBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            const key = btn.getAttribute('data-qty-change');
            const qty = parseInt(btn.getAttribute('data-qty'));
            this.updateCartQty(key, qty);
          });
        });

        this.interceptAddToCart();
      }

      openEngineModal() {
        if (this.engineModal) {
          this.engineModal.classList.add('active');
        }
      }

      closeEngineModal() {
        if (this.engineModal) {
          this.engineModal.classList.remove('active');
        }
      }

      openMenuDrawer() {
        if (this.menuDrawer) {
          this.menuDrawer.classList.add('active');
          this.drawerOverlay.classList.add('active');
        }
      }

      openCartDrawer() {
        if (this.cartDrawer) {
          this.cartDrawer.classList.add('active');
          this.drawerOverlay.classList.add('active');
        }
      }

      closeDrawers() {
        if (this.menuDrawer) {
          this.menuDrawer.classList.remove('active');
        }
        if (this.cartDrawer) {
          this.cartDrawer.classList.remove('active');
        }
        if (this.drawerOverlay) {
          this.drawerOverlay.classList.remove('active');
        }
      }

      updateCartQty(key, qty) {
        fetch('/cart/change.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            id: key,
            quantity: qty
          })
        })
        .then(response => response.json())
        .then(data => {
          this.refreshCart();
        });
      }

      refreshCart() {
        fetch('/cart.js')
          .then(response => response.json())
          .then(cart => {
            const cartCount = this.querySelector('[data-cart-count]');
            if (cartCount) {
              cartCount.textContent = cart.item_count;
            }

            const cartTotal = this.querySelector('[data-cart-total]');
            if (cartTotal) {
              cartTotal.textContent = this.formatMoney(cart.total_price);
            }

            const cartItemsContainer = this.querySelector('[data-cart-items]');
            if (cartItemsContainer) {
              this.renderCartItems(cart);
            }
          });
      }

      renderCartItems(cart) {
        const cartItemsContainer = this.querySelector('[data-cart-items]');
        if (!cartItemsContainer) return;

        if (cart.item_count === 0) {
          cartItemsContainer.innerHTML = '<p style="text-align: center; padding: 40px 20px; color: {{ block.settings.drawer_text_color }};">Your cart is empty</p>';
          const footer = this.querySelector('.marine-header-cart-footer-{{ ai_gen_id }}');
          if (footer) footer.style.display = 'none';
          return;
        }

        let html = '';
        cart.items.forEach(item => {
          html += `
            <div class="marine-header-cart-item-{{ ai_gen_id }}">
              <img src="${item.image}" alt="${item.title}" class="marine-header-cart-item-img-{{ ai_gen_id }}">
              <div class="marine-header-cart-item-info-{{ ai_gen_id }}">
                <div class="marine-header-cart-item-title-{{ ai_gen_id }}">${item.product_title}</div>
                <div class="marine-header-cart-item-price-{{ ai_gen_id }}">${this.formatMoney(item.final_line_price)}</div>
                <div class="marine-header-cart-qty-{{ ai_gen_id }}">
                  <button class="marine-header-cart-qty-btn-{{ ai_gen_id }}" data-qty-change="${item.key}" data-qty="${item.quantity - 1}">-</button>
                  <input type="number" value="${item.quantity}" class="marine-header-cart-qty-input-{{ ai_gen_id }}" readonly>
                  <button class="marine-header-cart-qty-btn-{{ ai_gen_id }}" data-qty-change="${item.key}" data-qty="${item.quantity + 1}">+</button>
                </div>
              </div>
            </div>
          `;
        });

        cartItemsContainer.innerHTML = html;

        const footer = this.querySelector('.marine-header-cart-footer-{{ ai_gen_id }}');
        if (footer) footer.style.display = 'block';

        this.qtyChangeBtns = this.querySelectorAll('[data-qty-change]');
        this.qtyChangeBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            const key = btn.getAttribute('data-qty-change');
            const qty = parseInt(btn.getAttribute('data-qty'));
            this.updateCartQty(key, qty);
          });
        });
      }

      interceptAddToCart() {
        document.addEventListener('submit', (e) => {
          if (e.target.matches('form[action="/cart/add"]')) {
            e.preventDefault();
            const formData = new FormData(e.target);

            fetch('/cart/add.js', {
              method: 'POST',
              body: formData
            })
            .then(response => response.json())
            .then(data => {
              this.refreshCart();
              this.openCartDrawer();
            });
          }
        });
      }

      formatMoney(cents) {
        const dollars = (cents / 100).toFixed(2);
        return `$${dollars}`;
      }
    }

    customElements.define('marine-header-{{ ai_gen_id }}', MarineHeader{{ ai_gen_id }});
  })();
</script>

