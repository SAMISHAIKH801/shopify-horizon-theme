                              <div class="marine-header-megamenu-product-title-{{ ai_gen_id }}">{{ product.title }}</div>
                              <div class="marine-header-megamenu-product-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
                            </a>
                          {% endif %}
                        {% else %}
                          <a href="{{ child_link.url }}" class="marine-header-megamenu-link-{{ ai_gen_id }}">
