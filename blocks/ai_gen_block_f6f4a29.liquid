            <div style="background: #f4f4f4; padding: 60px; text-align: center; border-radius: 8px;">
              <svg width="100" height="100" viewBox="0 0 100 100" fill="#ccc">
                <rect width="100" height="100" rx="8"/>
              </svg>
            </div>
          {% endif %}
        </div>
        <div class="marine-header-modal-right-{{ ai_gen_id }}">
          <h2 class="marine-header-modal-title-{{ ai_gen_id }}">{{ block.settings.engine_modal_title }}</h2>
          <form action="/search" method="get">
            {% for i in (1..5) %}
              {% assign label_key = 'engine_field_' | append: i | append: '_label' %}
              {% assign options_key = 'engine_field_' | append: i | append: '_options' %}
              {% if block.settings[label_key] != blank %}
                <div class="marine-header-modal-field-{{ ai_gen_id }}">
                  <label class="marine-header-modal-label-{{ ai_gen_id }}">{{ block.settings[label_key] }}</label>
                  <select name="field_{{ i }}" class="marine-header-modal-select-{{ ai_gen_id }}">
                    <option value="">Select {{ block.settings[label_key] }}</option>
                    {% assign options = block.settings[options_key] | split: ',' %}
                    {% for option in options %}
                      <option value="{{ option | strip }}">{{ option | strip }}</option>
                    {% endfor %}
                  </select>
                </div>
              {% endif %}
            {% endfor %}
            <button type="submit" class="marine-header-modal-search-btn-{{ ai_gen_id }}">Search</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <div class="marine-header-drawer-overlay-{{ ai_gen_id }}" data-drawer-overlay></div>

  <div class="marine-header-drawer-{{ ai_gen_id }}" data-menu-drawer-container>
    <div class="marine-header-drawer-header-{{ ai_gen_id }}">
      <div class="marine-header-logo-{{ ai_gen_id }}">
        {% if block.settings.logo %}
          <img src="{{ block.settings.logo | image_url: width: 120 }}" alt="{{ shop.name }}" style="max-height: 40px;">
        {% else %}
          <span style="font-size: 18px; font-weight: 700; color: {{ block.settings.drawer_text_color }};">{{ shop.name }}</span>
        {% endif %}
      </div>
      <div style="display: flex; gap: 10px;">
        <button class="marine-header-icon-btn-{{ ai_gen_id }}">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </button>
        <button class="marine-header-icon-btn-{{ ai_gen_id }}" data-cart-drawer>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="9" cy="21" r="1"></circle>
            <circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
          </svg>
        </button>
        <button class="marine-header-drawer-close-{{ ai_gen_id }}" data-drawer-close>&times;</button>
      </div>
    </div>
    <div class="marine-header-drawer-body-{{ ai_gen_id }}">
      <div style="margin-bottom: 20px;">
        <form action="/search" method="get" class="marine-header-search-form-{{ ai_gen_id }}">
          <input
            type="search"
            name="q"
            class="marine-header-search-input-{{ ai_gen_id }}"
            placeholder="{{ block.settings.search_placeholder }}"
            autocomplete="off"
          >
        </form>
      </div>
      <button class="marine-header-engine-btn-{{ ai_gen_id }}" data-engine-modal style="width: 100%; margin-bottom: 20px;">
        {{ block.settings.engine_button_text }}
      </button>
      <ul class="marine-header-mobile-menu-{{ ai_gen_id }}" data-mobile-menu>
        {% if block.settings.main_menu != blank %}
          {% for link in linklists[block.settings.main_menu].links %}
            <li class="marine-header-mobile-menu-item-{{ ai_gen_id }}">
              {% if link.links.size > 0 %}
                <a href="#" class="marine-header-mobile-menu-link-{{ ai_gen_id }}" data-parent-link="{{ forloop.index }}">
                  {{ link.title }}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="9 18 15 12 9 6"></polyline>
                  </svg>
                </a>
                <div class="marine-header-mobile-submenu-{{ ai_gen_id }}" data-submenu="{{ forloop.index }}">
                  <button class="marine-header-mobile-back-{{ ai_gen_id }}" data-back-btn>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="15 18 9 12 15 6"></polyline>
                    </svg>
                    {{ link.title }}
                  </button>
                  <div class="marine-header-mobile-products-grid-{{ ai_gen_id }}">
                    {% for child_link in link.links %}
                      {% if child_link.url contains '/products/' %}
                        {% assign product_handle = child_link.url | split: '/products/' | last | split: '?' | first %}
                        {% assign product = all_products[product_handle] %}
                        {% if product %}
                          <a href="{{ product.url }}" class="marine-header-megamenu-product-{{ ai_gen_id }}">
                            {% if product.featured_image %}
                              <img src="{{ product.featured_image | image_url: width: 150 }}" alt="{{ product.title }}" class="marine-header-megamenu-product-img-{{ ai_gen_id }}">
                            {% endif %}
                            <div class="marine-header-megamenu-product-title-{{ ai_gen_id }}">{{ product.title }}</div>
                            <div class="marine-header-megamenu-product-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
                          </a>
                        {% endif %}
                      {% else %}
                        <a href="{{ child_link.url }}" class="marine-header-megamenu-link-{{ ai_gen_id }}">
                          {{ child_link.title }}
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              {% else %}
                <a href="{{ link.url }}" class="marine-header-mobile-menu-link-{{ ai_gen_id }}">{{ link.title }}</a>
              {% endif %}
