{% comment %} 

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

<link rel="stylesheet" href="https://unpkg.com/flickity@2/dist/flickity.min.css">
<script src="https://unpkg.com/flickity@2/dist/flickity.pkgd.min.js" defer></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | append: 'px' }};
    padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
    padding-left: {{ section.settings.padding_left | append: 'px' }};
    padding-right: {{ section.settings.padding_right | append: 'px' }};
  }

  /* Layout Custom Variables */
  :root {
    --desktop-cards: {{ section.settings.products_per_row_desktop }};
    --tablet-cards: {{ section.settings.products_per_row_tablet }};
    --mobile-cards: {{ section.settings.products_per_row_mobile }};
  }

  /* FIXED: Dynamic Container Width Lock */
  .custom-carousel-wrapper {
    margin: 0 auto !important;
    position: relative;
    box-sizing: border-box;
    font-family: 'Inter', sans-serif;
    /* width: 100% !important; */
    display: block !important;
    
    {% if section.settings.container_width == 'default' %}
      max-width: 1200px !important;
    {% elsif section.settings.container_width == 'custom' %}
      max-width: {{ section.settings.custom_max_width | append: 'px' }} !important;
    {% else %}
      max-width: 100% !important;
    {% endif %}
  }
  
  .custom-carousel-title {
    font-family: 'Bebas Neue', sans-serif;
    text-align: center;
    font-size: 3rem;
    font-weight: 400;
    text-transform: uppercase;
    margin-bottom: 35px;
    letter-spacing: 2px;
    color: #000;
    content-visibility: auto;
  }
  
  /* FIXED: Carousel box constraints inside wrapper */
  .custom-product-carousel {
    width: 100% !important;
    max-width: 100% !important;
    display: flex;
    overflow: hidden;
    flex-wrap: nowrap;
    box-sizing: border-box;
  }

  .custom-product-carousel.flickity-enabled {
    display: block !important;
  }

  .custom-product-carousel .flickity-viewport {
    display: flex !important;
    align-items: stretch !important;
    width: 100% !important;
    max-width: 100% !important;
  }
  
  /* Customizer Card Background Target */
  .custom-product-carousel .carousel-cell-card {
    width: calc(100% / var(--desktop-cards) - 15px);
    margin-right: 20px;
    flex-shrink: 0;
    background-color: {{ section.settings.card_bg_color }};
    border: 1px solid #111;
    padding: 20px 15px;
    box-sizing: border-box;
    display: flex !important;
    flex-direction: column;
    align-items: center;
    text-align: center;
    justify-content: space-between;
    height: auto !important;
    will-change: transform;
  }

  /* Product Content Typography & Hierarchy */
  .card-badge-text {
    font-family: 'Inter', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: #002d62;
    margin-bottom: 10px;
  }
  
  .card-image-wrap {
    width: 100%;
    height: 180px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 15px;
  }
  
  .card-image-wrap img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    height: auto;
  }
  
  .card-product-title {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #002d62;
    margin: 10px 0;
    text-decoration: none;
    line-height: 1.3;
    width: 100%;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 48px;
  }
  
  .card-shop-btn {
    font-family: 'Inter', sans-serif;
    background-color: #ff1e27;
    color: #fff;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 700;
    border: none;
    text-decoration: none;
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: auto;
    transition: background 0.2s ease;
    width: 100%;
    box-sizing: border-box;
  }
  
  .card-shop-btn:hover {
    background-color: #d6141c;
  }

  /* Slider Controller Layouts */
  .flickity-prev-next-button {
    width: 44px;
    height: 44px;
    background: #e9b422!important;
    border-radius: 50%;
    transition: background 0.2s ease, opacity 0.2s ease;
    z-index: 2;
  }
  
  .flickity-prev-next-button:hover {
    background: #e6b800 !important;
  }
  
  .flickity-prev-next-button.previous { 
    left: 5px; 
    opacity: 0.7;
  }
  .flickity-prev-next-button.previous:hover {
    opacity: 1;
  }
  .flickity-prev-next-button.next { right: 5px; }
  
  .flickity-page-dots { bottom: -25px; }
  .flickity-page-dots .dot { background: #333; margin: 0 6px; opacity: 0.2; }
  .flickity-page-dots .dot.is-selected { opacity: 1; }

  /* Responsive Queries */
  @media screen and (max-width: 1024px) {
    .custom-product-carousel .carousel-cell-card {
      width: calc(100% / var(--tablet-cards) - 12px);
      margin-right: 15px;
    }
    .custom-carousel-title { font-size: 2.5rem; }
  }
  
  @media screen and (max-width: 767px) {
    .custom-product-carousel .carousel-cell-card {
      width: calc(100% / var(--mobile-cards) - 8px);
      margin-right: 10px;
      padding: 15px 10px;
    }
    .flickity-prev-next-button.previous { left: 0px; }
    .flickity-prev-next-button.next { right: 0px; }
    .custom-carousel-title {       
      font-size: 24px;
      letter-spacing: normal; 
    }
    .card-product-title {
      font-size: 16px;
    }
  }
{%- endstyle -%}

<div class="custom-carousel-wrapper section-{{ section.id }}-padding">
  {% if section.settings.section_title != blank %}
    <h2 class="custom-carousel-title">{{ section.settings.section_title }}</h2>
  {% endif %}

  <div class="custom-product-carousel" data-flickity-init>
    {% assign selected_collection = collections[section.settings.collection] %}
    {% if selected_collection != blank and selected_collection.all_products_count > 0 %}
      
      {% for product in selected_collection.products limit: section.settings.max_products %}
        <div class="carousel-cell-card">
          <div class="card-badge-text">
            {% if section.settings.optional_percentage_text != blank %}
              {{ section.settings.optional_percentage_text }}
            {% else %}
              Optional % Off
            {% endif %}
          </div>
          
          <div class="card-image-wrap">
            {% if product.featured_image != blank %}
              <img src="{{ product.featured_image | image_url: width: 400 }}" 
                   alt="{{ product.title | escape }}" 
                   loading="lazy"
                   width="400"
                   height="{{ 400 | divided_by: product.featured_image.aspect_ratio | round }}">
            {% else %}
              {{ 'product-1' | placeholder_svg_tag }}
            {% endif %}
          </div>

          <a href="{{ product.url }}" class="card-product-title">
            {% if section.settings.use_custom_product_text and section.settings.optional_product_text != blank %}
              {{ section.settings.optional_product_text }}
            {% else %}
              {{ product.title }}
            {% endif %}
          </a>

          <a href="{{ product.url }}" class="card-shop-btn">Shop Now</a>
        </div>
      {% endfor %}

    {% else %}
      {% for i in (1..6) %}
        <div class="carousel-cell-card">
          <div class="card-badge-text">Optional % Off</div>
          <div class="card-image-wrap">
            {{ 'product-' | append: i | placeholder_svg_tag }}
          </div>
          <a href="#" class="card-product-title">Optional Text</a>
          <a href="#" class="card-shop-btn">Shop Now</a>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    var initCarousel = function() {
      var elem = document.querySelector('[data-flickity-init]');
      if (elem && !elem.classList.contains('flickity-enabled')) {
        var flkty = new Flickity(elem, {
          cellAlign: 'left',
          contain: true,
          wrapAround: true,
          groupCells: 1,
          prevNextButtons: true,
          pageDots: true,
          adaptiveHeight: false,
          watchCSS: false
        });
        
        setTimeout(function() {
          flkty.resize();
        }, 150);
      }
    };

    initCarousel();
    
    if (Shopify.designMode) {
      document.addEventListener('shopify:section:load', initCarousel);
    }
  });
</script>

