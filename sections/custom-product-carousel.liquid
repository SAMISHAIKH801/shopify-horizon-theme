{% comment %} 
<!-- Performance Preconnect & Optimized CDN Assets -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

<link rel="stylesheet" href="https://unpkg.com/flickity@2/dist/flickity.min.css" media="print" onload="this.media='all'">
<script src="https://unpkg.com/flickity@2/dist/flickity.pkgd.min.js" defer></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | append: 'px' }};
    padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
  }

  /* Layout Custom Variables */
  :root {
    --desktop-cards: {{ section.settings.products_per_row_desktop }};
    --tablet-cards: {{ section.settings.products_per_row_tablet }};
    --mobile-cards: {{ section.settings.products_per_row_mobile }};
  }

  .custom-carousel-wrapper {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 50px; /* Thora horizontal padding barhaya h safe zone k liye */
    position: relative;
    box-sizing: border-box;
    font-family: 'Inter', sans-serif;
  }
  
  .custom-carousel-title {
    font-family: 'Bebas Neue', sans-serif;
    text-align: center;
    font-size: 3rem;
    font-weight: 400;
    text-transform: uppercase;
    margin-bottom: 35px;
    letter-spacing: 2px;
    color: #000;
    content-visibility: auto; /* Browser performance booster */
  }
  
  /* Carousel View Setup */
  .custom-product-carousel {
    width: 100%;
    display: block;
  }
  
  /* Customizer Card Background Target */
  .custom-product-carousel .carousel-cell-card {
    width: calc(100% / var(--desktop-cards) - 15px);
    margin-right: 20px;
    background-color: {{ section.settings.card_bg_color }};
    border: 1px solid #111;
    padding: 15px 10px;
    box-sizing: border-box;
    display: flex !important;
    flex-direction: column;
    align-items: center;
    text-align: center;
    justify-content: space-between;
    min-height: 440px;
    will-change: transform; /* Hardware acceleration for buttery smooth scrolling */
  }

  /* Product Content Typography & Hierarchy */
  .card-badge-text {
    font-family: 'Inter', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: #002d62;
    margin-bottom: 0px;
  }
  
  .card-image-wrap {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 10px;
  }
  
  .card-image-wrap img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    height: auto;
  }
  
  .card-product-title {
    font-family: 'Inter', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: #002d62;
    margin: 0px 0 0px 0;
    text-decoration: none;
    line-height: 1.3;
    width: 100%;
    border-top: none !important;
    padding-top: 0 !important;
  }
  
  .card-shop-btn {
    font-family: 'Inter', sans-serif;
    background-color: #ff1e27;
    color: #fff;
    padding: 9px 18px;
    font-size: 14px;
    font-weight: 700;
    border: none;
    text-decoration: none;
    display: inline-block;
    text-transform: capitalize;
    letter-spacing: 0.5px;
    transition: background 0.2s ease, transform 0.1s ease;
  }
  
  .card-shop-btn:hover {
    background-color: #d6141c;
  }

  /* Slider Controller Layouts */
  .flickity-viewport {
    transition: height 0.2s;
  }
  
  .flickity-prev-next-button {
    width: 44px;
    height: 44px;
    background: #e9b422!important;
    border-radius: 50%;
    transition: background 0.2s ease, opacity 0.2s ease;
    z-index: 2;
  }
  
  .flickity-prev-next-button:hover {
    background: #e6b800 !important;
  }
  
  /* Left Arrow customization to look lighter by default */
  .flickity-prev-next-button.previous { 
    left: -15px; 
    opacity: 0.5;
  }
  .flickity-prev-next-button.previous:hover {
    opacity: 1;
  }
  .flickity-prev-next-button.next { right: -15px; }
  
  .flickity-page-dots { bottom: -35px; }
  .flickity-page-dots .dot { background: #333; margin: 0 6px; opacity: 0.2; }
  .flickity-page-dots .dot.is-selected { opacity: 1; }

  /* Responsive Queries */
  @media screen and (max-width: 1024px) {
    .custom-product-carousel .carousel-cell-card {
      width: calc(100% / var(--tablet-cards) - 12px);
      margin-right: 15px;
    }
    .custom-carousel-wrapper { padding: 0 30px; }
    .custom-carousel-title { font-size: 2.5rem; }
  }
  
  @media screen and (max-width: 767px) {
    .custom-product-carousel .carousel-cell-card {
      width: calc(100% / var(--mobile-cards) - 8px);
      margin-right: 10px;
      min-height: 400px;
      padding: 20px 15px;
    }
    .custom-carousel-wrapper { padding: 0 20px; }
    .flickity-prev-next-button.previous { left: -10px; }
    .flickity-prev-next-button.next { right: -10px; }
    .custom-carousel-title {       
      font-size: 24px;
      letter-spacing: normal; 
    }
    .card-product-title {
      font-size: 16px;
    }
  }

  #shopify-section-template--22617970213108__custom_product_carousel_AHCHpB {
    padding: 50px 0px;
  }
{%- endstyle -%}

<div class="custom-carousel-wrapper section-{{ section.id }}-padding">
  {% if section.settings.section_title != blank %}
    <h2 class="custom-carousel-title">{{ section.settings.section_title }}</h2>
  {% endif %}

  <div class="custom-product-carousel" data-flickity-init>
    {% assign selected_collection = collections[section.settings.collection] %}
    {% if selected_collection != blank and selected_collection.all_products_count > 0 %}
      
      {% for product in selected_collection.products limit: section.settings.max_products %}
        <div class="carousel-cell-card">
          <div class="card-badge-text">
            {% if section.settings.optional_percentage_text != blank %}
              {{ section.settings.optional_percentage_text }}
            {% else %}
              Optional % Off
            {% endif %}
          </div>
          
          <div class="card-image-wrap">
            {% if product.featured_image != blank %}
              <!-- Performance Optimized Image Loading Engine -->
              <img src="{{ product.featured_image | image_url: width: 450 }}" 
                   alt="{{ product.title | escape }}" 
                   loading="lazy"
                   width="450"
                   height="{{ 450 | divided_by: product.featured_image.aspect_ratio | round }}">
            {% else %}
              {{ 'product-1' | placeholder_svg_tag }}
            {% endif %}
          </div>

          <a href="{{ product.url }}" class="card-product-title">
            {% if section.settings.use_custom_product_text and section.settings.optional_product_text != blank %}
              {{ section.settings.optional_product_text }}
            {% else %}
              {{ product.title }}
            {% endif %}
          </a>

          <a href="{{ product.url }}" class="card-shop-btn">Shop Now</a>
        </div>
      {% endfor %}

    {% else %}
      {% for i in (1..6) %}
        <div class="carousel-cell-card">
          <div class="card-badge-text">Optional % Off</div>
          <div class="card-image-wrap">
            {{ 'product-' | append: i | placeholder_svg_tag }}
          </div>
          <a href="#" class="card-product-title">Optional Text</a>
          <a href="#" class="card-shop-btn">Shop Now</a>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    var initCarousel = function() {
      var elem = document.querySelector('[data-flickity-init]');
      if (elem && !elem.classList.contains('flickity-enabled')) {
        var flkty = new Flickity(elem, {
          cellAlign: 'center', /* Center alignment handles the left cutoff glitch elegantly */
          contain: false,      /* Left-right boundary control dynamically allows right cutoff trailing layout */
          wrapAround: true,
          groupCells: 1,
          prevNextButtons: true,
          pageDots: true,
          adaptiveHeight: false
        });
      }
    };

    initCarousel();
    
    if (Shopify.designMode) {
      document.addEventListener('shopify:section:load', initCarousel);
    }
  });
</script>

