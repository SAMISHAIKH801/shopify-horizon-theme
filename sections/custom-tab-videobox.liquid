    },
    {
      "type": "text",
      "id": "tab_2_video_url",
      "label": "Tab 2 YouTube Video Link"
    },
    {
      "type": "image_picker",
      "id": "tab_2_img",
      "label": "Tab 2 Right Box Bg Image"
    },
    {
      "type": "text",
      "id": "tab_2_box_title",
      "label": "Tab 2 Right Box Text"
    },
    {
      "type": "text",
      "id": "tab_2_btn_label",
      "label": "Tab 2 Button Label"
    },
    {
      "type": "url",
      "id": "tab_2_btn_url",
      "label": "Tab 2 Button Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Video Tabs Section"
    }
  ]
}
{% endschema %}