  .accordion-inner-grid-content {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    text-align: center;
    margin-bottom: 25px;
    align-items: start;
  }
  .box-label-title {
    display: block;
    font-size: 15px;
    color: #000000;
    font-weight: 500 !important;
    margin-bottom: 0px;
  }
  .box-value-text, .box-value-text-rt, .box-value-text-rt p {
    font-size: 15px;
    color: #444444;
    margin: 0;
    font-weight: normal;
    font-family: Arial, sans-serif;
  }
  .box-value-text-rt a {
    color: #0000ff;
    text-decoration: underline;
  }

  /* Footer Action Button Specs */
  .accordion-action-footer {
    text-align: center;
  }
  .accordion-cta-button {
    display: inline-block;
    background-color: #cc0000;
    color: #ffffff;
    padding: 14px 40px;
    font-size: 15px;
    font-weight: 500 !important;
    text-decoration: none;
    text-transform: capitalize;
    transition: background-color 0.2s ease;
  }
  .accordion-cta-button:hover {
    background-color: #b30000;
  }
  
  .no-accordion-notice {
    text-align: center; 
    color: #666; 
    font-family: Arial, sans-serif; 
    padding: 20px;
  }

  /* Responsive Fluid Scaling Media Queries */
  @media screen and (max-width: 767px) {
    .engine-tabs-nav {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
    .tab-btn {
      min-width: unset;
      font-size: 14px;
      padding: 12px 5px;
    }
    .accordion-inner-grid-content {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .accordion-trigger-header {
      font-size: 16px;
      padding: 14px 15px;
    }
    .acc-icon-state {
      font-size: 22px;
      width: 20px;
      height: 20px;
    }
    .active-tab-title-banner {
      font-size: 18px;
      padding: 12px;
    }
    .accordion-card-item.is-open .accordion-panel-body {
      padding: 25px 15px;
    }
    .accordion-cta-button {
      width: 100%;
      box-sizing: border-box;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const sectionContainer = document.querySelector(".section-{{ section.id }}");
    if (!sectionContainer) return;

    // 1. Core Tab Switching Logic
    const tabButtons = sectionContainer.querySelectorAll(".tab-btn");
    const tabPanels = sectionContainer.querySelectorAll(".tab-panel-content");
    const bannerElements = sectionContainer.querySelectorAll(".active-tab-title-banner");

    tabButtons.forEach(btn => {
      btn.addEventListener("click", function () {
        const targetId = this.getAttribute("data-tab-target");
        const cleanId = targetId.replace(`tab-{{ section.id }}-`, "");

        tabButtons.forEach(b => b.classList.remove("active"));
        tabPanels.forEach(p => p.classList.remove("active-panel"));
        bannerElements.forEach(banner => banner.classList.remove("show-banner"));

        this.classList.add("active");
        
        const activePanel = sectionContainer.querySelector(`#${targetId}`);
        if(activePanel) {
          activePanel.classList.add("active-panel");
          // Reset other tabs items when shifting views
          activePanel.querySelectorAll('.accordion-card-item').forEach(card => {
            card.classList.remove('is-open');
            card.querySelector('.accordion-trigger-header').setAttribute('aria-expanded', 'false');
            card.querySelector('.acc-icon-state').textContent = '+';
          });
        }

        const activeBanner = sectionContainer.querySelector(`#banner-tab-{{ section.id }}-${cleanId}`);
        if(activeBanner) activeBanner.classList.add("show-banner");
      });
    });

    // 2. High-Performance Smooth Accordion Toggle Event Handles
    const accordionHeaders = sectionContainer.querySelectorAll(".accordion-trigger-header");
    accordionHeaders.forEach(header => {
      header.addEventListener("click", function () {
        const parentCard = this.closest(".accordion-card-item");
        const iconState = this.querySelector(".acc-icon-state");
        const isOpen = parentCard.classList.contains("is-open");

        if (isOpen) {
          parentCard.classList.remove("is-open");
          this.setAttribute("aria-expanded", "false");
          if (iconState) iconState.textContent = "+";
        } else {
          parentCard.classList.add("is-open");
          this.setAttribute("aria-expanded", "true");
          if (iconState) iconState.textContent = "—";
        }
      });
    });
  });
</script>

