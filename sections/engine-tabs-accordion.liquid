          "info": "Wahi exact Unique Tab ID likhein jis tab ke andar aap ye particular accordion card dikhana chahte hain."
        },
        {
          "type": "text",
          "id": "accordion_title",
          "label": "Accordion Row Title",
          "default": "BF5A"
        },
        {
          "type": "header",
          "content": "Box Content 1 Column"
        },
        {
          "type": "text",
          "id": "box1_title",
          "label": "Box 1 - Headline Title",
          "default": "Gear Lube Capacity:"
        },
        {
          "type": "text",
          "id": "box1_text",
          "label": "Box 1 - Value Description Text",
          "default": "4.2 oz."
        },
        {
          "type": "header",
          "content": "Box Content 2 Column"
        },
        {
          "type": "text",
          "id": "box2_title",
          "label": "Box 2 - Headline Title",
          "default": "Notes:"
        },
        {
          "type": "text",
          "id": "box2_text",
          "label": "Box 2 - Value Description Text",
          "default": "Check every 100 hours"
        },
        {
          "type": "header",
          "content": "Box Content 3 Column"
        },
        {
          "type": "text",
          "id": "box3_title",
          "label": "Box 3 - Headline Title",
          "default": "Recommended Gear Lube:"
        },
        {
          "type": "richtext",
          "id": "box3_text",
          "label": "Box 3 - Value/Link Description Text",
          "default": "<p><a href=\"#\">80W-90 Marine Gear Lube</a></p>"
        },
        {
          "type": "header",
          "content": "Footer CTA Button Settings"
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Action Button Label Text",
          "default": "Shop Yamaha Outboard Parts"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Action Button Target URL Redirect"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Engine Tabs Accordion",
      "blocks": [
        { "type": "tab_header", "settings": { "title": "BF2 - BF8", "tab_id": "tab1" } },
        { "type": "tab_header", "settings": { "title": "BF9.9 - BF15", "tab_id": "tab2" } },
        { "type": "accordion_item", "settings": { "target_tab_id": "tab1", "accordion_title": "BF5A" } },
        { "type": "accordion_item", "settings": { "target_tab_id": "tab1", "accordion_title": "BF8A" } },
        { "type": "accordion_item", "settings": { "target_tab_id": "tab2", "accordion_title": "BF9.9A" } }
      ]
    }
  ]
}
{% endschema %}
