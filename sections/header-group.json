      "settings": {
        "custom_liquid": "<div class=\"yellow-features-bar\">\n  <div class=\"features-container\">\n    \n    <a href=\"#\" class=\"feature-item\">\n      <svg class=\"feature-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <rect x=\"1\" y=\"3\" width=\"15\" height=\"13\"></rect>\n        <polygon points=\"16 8 20 8 23 11 23 16 16 16 16 8\"></polygon>\n        <circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"></circle>\n        <circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"></circle>\n      </svg>\n      <span class=\"feature-text\">Free Shipping over $99*</span>\n    </a>\n\n    <a href=\"#\" class=\"feature-item mobile-hidden\">\n      <svg class=\"feature-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <line x1=\"12\" y1=\"1\" x2=\"12\" y2=\"23\"></line>\n        <path d=\"M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6\"></path>\n      </svg>\n      <span class=\"feature-text\">Earn up to 4.5% Back on Purchases</span>\n    </a>\n\n    <a href=\"#\" class=\"feature-item mobile-hidden\">\n      <svg class=\"feature-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\"></path>\n        <circle cx=\"8\" cy=\"10\" r=\"1\"></circle>\n        <circle cx=\"12\" cy=\"10\" r=\"1\"></circle>\n        <circle cx=\"16\" cy=\"10\" r=\"1\"></circle>\n      </svg>\n      <span class=\"feature-text\">Assistance From Boat Parts Experts</span>\n    </a>\n\n  </div>\n</div>\n\n<style>\n  /* Base Styles */\n  .yellow-features-bar {\n    background-color: #f9b715; /* Exact yellow/mustard color from screenshot */\n   \n    padding: 8px 30px;\n    width: 100%;\n    box-sizing: border-box;\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n  }\n\n  .features-container {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    max-width: 100%;\n    margin: 0 auto;\n    width: 100%;\n  }\n\n  /* Clickable Feature Items */\n  .feature-item {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    color: #000000; /* Black text and icons */\n    text-decoration: none;\n    font-weight: 700; /* Bold text as per screenshot */\n    font-size: 14px;\n    transition: opacity 0.2s ease;\n  }\n\n  .feature-item:hover {\n    opacity: 0.8;\n  }\n\n  /* Icon Sizing */\n  .feature-icon {\n    width: 18px;\n    height: 18px;\n    flex-shrink: 0;\n  }\n\n  /* Responsive/Mobile Styles */\n  @media screen and (max-width: 767px) {\n    .yellow-features-bar {\n      padding: 7px 15px;\n    }\n\n   .feature-item {\n    font-size: 12px;\n  \n}\n    .features-container {\n      justify-content: center; /* Center align on mobile */\n    }\n\n    .mobile-hidden {\n      display: none !important; /* Hides block 2 and 3 on mobile */\n    }\n  }\n</style>",
