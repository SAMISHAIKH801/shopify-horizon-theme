      "settings": {
        "custom_liquid": "<div class=\"top-announcement-bar\">\n  <div class=\"top-bar-container\">\n    \n    <div class=\"top-bar-left\">\n      <span>Contact Our Parts Experts: <a href=\"tel:1-888-625-5460\" class=\"top-bar-link underline\">1-888-625-5460</a></span>\n      <span class=\"desktop-only\"> | B2B: <a href=\"tel:941-900-4810\" class=\"top-bar-link underline\">941-900-4810</a></span>\n      <span class=\"desktop-only\"> | Hablamos Español</span>\n    </div>\n\n    <div class=\"top-bar-right desktop-only\">\n      <a href=\"#\" class=\"top-bar-link\">B2B</a>\n      <a href=\"#\" class=\"top-bar-link\">Government Sales</a>\n      <a href=\"#\" class=\"top-bar-link\">Earn PartsVu Rewards</a>\n      <a href=\"#\" class=\"top-bar-link\">Customer Service</a>\n    </div>\n\n  </div>\n</div>\n\n<style>\n  /* Base Styles */\n  .top-announcement-bar {\n    background-color: #005a70;\n    color: #ffffff;\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n    font-size: 13px;\n    padding: 8px 30px; /* Padding thodi badha di hai taake full width me acha lage */\n        border-bottom: 1px solid #00cbd638;\n    width: 100%;\n    box-sizing: border-box;\n  }\n\n  .top-bar-container {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    max-width: 100% !important; /* Yahan se 1200px hata kar 100% kar diya hai */\n    margin: 0 auto;\n    width: 100%;\n  }\n\n  .top-bar-link {\n    color: #ffffff;\n    text-decoration: none;\n    transition: opacity 0.2s ease;\n  }\n\n  .top-bar-link:hover {\n    opacity: 0.8;\n  }\n\n  .underline {\n    text-decoration: underline;\n  }\n\n  /* Right side links spacing */\n  .top-bar-right {\n    display: flex;\n    gap: 20px;\n  }\n\n  /* Responsive/Mobile Styles */\n  @media screen and (max-width: 767px) {\n    .top-announcement-bar {\n      padding: 6px 15px; /* Mobile par padding thodi kam ki hai */\n    }\n\n    .top-bar-container {\n      justify-content: center;\n    }\n    \n    .top-bar-left {\n      text-align: center;\n      width: 100%;\n    }\n\n    .desktop-only {\n      display: none !important;\n    }\n  }\n</style>",
