{% comment %} ── SHOP BY ENGINE POPUP ── {% endcomment %}
<div class="sbe-overlay" id="sbeOverlay">
  <div class="sbe-modal" role="dialog" aria-modal="true" aria-label="Shop Parts by Engine">
    <button class="sbe-close" id="sbeClose" aria-label="Close">&#x2715;</button>

    {%- comment -%} Left: engine visuals {%- endcomment -%}
    <div class="sbe-img-side">
      <div class="sbe-engines">
        <div class="sbe-engine-col">
          <div class="sbe-engine-placeholder" style="height:110px;">Yamaha</div>
          <span class="sbe-engine-label">Yamaha</span>
        </div>
        <div class="sbe-engine-col">
          <div class="sbe-engine-placeholder" style="height:145px;">Mercury</div>
          <span class="sbe-engine-label">Mercury</span>
        </div>
        <div class="sbe-engine-col">
          <div class="sbe-engine-placeholder" style="height:120px;">Suzuki</div>
          <span class="sbe-engine-label">Suzuki</span>
        </div>
      </div>
    </div>

    {%- comment -%} Right: form {%- endcomment -%}
    <div class="sbe-form-side">
      <div class="sbe-title">Shop Parts<br><span>By Engine</span></div>

      <select class="sbe-select" id="sbeMake">
        <option value="">Engine Make</option>
        <option value="yamaha">Yamaha</option>
        <option value="mercury">Mercury</option>
        <option value="mercruiser">MerCruiser</option>
        <option value="suzuki">Suzuki</option>
        <option value="honda">Honda</option>
      </select>

      <select class="sbe-select" id="sbeModel" disabled>
        <option value="">Model</option>
      </select>

      <select class="sbe-select" id="sbeYear" disabled>
        <option value="">Year</option>
      </select>

      <button class="sbe-btn-search" id="sbeSearchBtn">Search</button>
    </div>
  </div>
</div>

<script>
(function() {
  var sbeModels = {
    yamaha: ['F4','F6','F8','F9.9','F15','F20','F25','F40','F50','F60','F70','F75','F90','F100','F115','F150','F175','F200','F225','F250','F300','F350'],
    mercury: ['2.5','3.5','4','5','6','8','9.9','15','20','25','30','40','50','60','75','90','115','150','175','200','225','250','300','350','400 Verado'],
    mercruiser: ['3.0L TKS','3.0L MPI','4.3L MPI','5.0L MPI','5.7L MPI','6.2L MPI','8.1L MPI','350 MAG','496 MAG','QSD 2.0','QSD 4.2'],
    suzuki: ['DF2.5','DF4','DF6','DF8','DF9.9','DF15','DF20','DF25','DF40','DF50','DF60','DF70','DF90','DF115','DF140','DF150','DF175','DF200','DF225','DF250','DF300','DF350'],
    honda: ['BF2.3','BF4','BF5','BF6','BF8','BF9.9','BF15','BF20','BF25','BF30','BF40','BF50','BF60','BF75','BF90','BF115','BF135','BF150','BF175','BF200','BF225','BF250']
  };

  function openSbe() {
    document.getElementById('sbeOverlay').classList.add('sbe-active');
    document.body.style.overflow = 'hidden';
  }
  function closeSbe() {
    document.getElementById('sbeOverlay').classList.remove('sbe-active');
    document.body.style.overflow = '';
  }

  document.getElementById('sbeClose').addEventListener('click', closeSbe);
  document.getElementById('sbeOverlay').addEventListener('click', function(e) {
    if (e.target === this) closeSbe();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeSbe();
  });

  document.getElementById('sbeMake').addEventListener('change', function() {
    var make = this.value;
    var modelSel = document.getElementById('sbeModel');
    var yearSel = document.getElementById('sbeYear');
    modelSel.innerHTML = '<option value="">Model</option>';
    yearSel.innerHTML = '<option value="">Year</option>';
    modelSel.disabled = true;
    yearSel.disabled = true;
    if (make && sbeModels[make]) {
      sbeModels[make].forEach(function(m) {
        var o = document.createElement('option');
        o.value = m; o.textContent = m;
        modelSel.appendChild(o);
      });
      modelSel.disabled = false;
    }
  });

  document.getElementById('sbeModel').addEventListener('change', function() {
    var yearSel = document.getElementById('sbeYear');
    yearSel.innerHTML = '<option value="">Year</option>';
    yearSel.disabled = true;
    if (this.value) {
      for (var y = 2025; y >= 1985; y--) {
        var o = document.createElement('option');
        o.value = y; o.textContent = y;
        yearSel.appendChild(o);
      }
      yearSel.disabled = false;
    }
  });

  document.getElementById('sbeSearchBtn').addEventListener('click', function() {
    var make = document.getElementById('sbeMake').value;
    var model = document.getElementById('sbeModel').value;
    var year = document.getElementById('sbeYear').value;
    if (!make || !model || !year) {
      alert('Please select Engine Make, Model, and Year.');
      return;
    }
    window.location.href = '/search?q=' + encodeURIComponent(make + ' ' + model + ' ' + year);
  });

  // Expose globally so the button in header can call it
  window.openShopByEngine = openSbe;
})();
</script>














