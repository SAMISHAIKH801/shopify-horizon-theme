{% comment %} <button type="button" class="custom-hamburger-trigger" id="openMobileDrawer" aria-label="Open Menu">
  <span class="hamburger-bar"></span>
  <span class="hamburger-bar"></span>
  <span class="hamburger-bar"></span>
</button>

<div id="customMobileDrawer" class="custom-m-drawer">
  <div class="custom-m-drawer-inner">
    
    <div class="custom-m-drawer-header">
      <span class="custom-drawer-logo">MENU</span>
      <button type="button" id="closeMobileDrawer" class="custom-drawer-close">&times;</button>
    </div>

    <div class="custom-m-engine-section">
      <button type="button" class="custom-m-engine-btn" id="openEnginePopup">
        Shop by Engine
      </button>
    </div>

    <nav class="custom-m-nav" id="mNavLayer1">
      <ul class="custom-m-menu-list">
        {%- for link in linklist.links -%}
          <li class="custom-m-menu-item">
            {%- if link.links != blank -%}
              <button type="button" class="custom-m-menu-link has-children" data-target="submenu-{{ forloop.index }}">
                {{ link.title | escape }}
                <span class="arrow-forward">&#10095;</span>
              </button>
            {%- else -%}
              <a href="{{ link.url }}" class="custom-m-menu-link">{{ link.title | escape }}</a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    {%- for link in linklist.links -%}
      {%- if link.links != blank -%}
        <div class="custom-m-submenu-panel" id="submenu-{{ forloop.index }}">
          <button type="button" class="custom-m-back-btn">&#10094; Back</button>
          <h3 class="custom-m-submenu-title">{{ link.title | escape }}</h3>
          
          <ul class="custom-m-menu-list">
            <li class="custom-m-menu-item">
              <a href="{{ link.url }}" class="custom-m-menu-link shop-all-link">Shop All {{ link.title | escape }}</a>
            </li>
            {%- for childlink in link.links -%}
              <li class="custom-m-menu-item">
                <a href="{{ childlink.url }}" class="custom-m-menu-link">{{ childlink.title | escape }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>
</div>

<div id="enginePopupModal" class="engine-popup-modal">
  <div class="engine-popup-content">
    <span class="close-popup">&times;</span>
    <h3>SHOP PARTS BY ENGINE</h3>
    <form action="/search" method="get">
      <div class="form-group">
        <select name="pf_v_engine_make" id="engineMake">
          <option value="">Engine Make</option>
          <option value="mercury">Mercury Marine</option>
          <option value="yamaha">Yamaha</option>
        </select>
      </div>
      <div class="form-group">
        <select name="pf_v_model" id="engineModel">
          <option value="">Model</option>
        </select>
      </div>
      <div class="form-group">
        <select name="pf_v_year" id="engineYear">
          <option value="">Year</option>
        </select>
      </div>
      <button type="submit" class="engine-search-submit">Search</button>
    </form>
  </div>
</div>

<style>
  /* Hamburger Button Trigger */
  .custom-hamburger-trigger {
    display: none; /* Desktop par hidden rahega */
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 18px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 99;
  }
  .hamburger-bar {
    width: 100%;
    height: 3px;
    background-color: #002d62; /* Theme color */
    border-radius: 2px;
  }

  /* Main Drawer Layout */
  .custom-m-drawer {
    position: fixed;
    top: 0;
    left: -100%; /* Shuru me slide out rahega */
    width: 100%;
    max-width: 400px;
    height: 100%;
    background: #fff;
    z-index: 99999;
    box-shadow: 5px 0 15px rgba(0,0,0,0.2);
    transition: left 0.3s ease-in-out;
    overflow: hidden;
  }
  .custom-m-drawer.is-open {
    left: 0;
  }
  .custom-m-drawer-inner {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .custom-m-drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px;
    background: #002d62;
    color: #fff;
  }
  .custom-drawer-logo { font-weight: bold; font-size: 16px; }
  .custom-drawer-close { background: none; border: none; color: #fff; font-size: 28px; cursor: pointer; }

  /* Shop By Engine Button styling like your yellow bar */
  .custom-m-engine-section { padding: 10px 15px; background: #f4f4f4; }
  .custom-m-engine-btn {
    width: 100%;
    padding: 14px;
    background: #ffcc00; /* Yellow Button */
    color: #000;
    border: none;
    font-weight: bold;
    font-size: 15px;
    text-transform: uppercase;
    cursor: pointer;
    letter-spacing: 0.5px;
  }

  /* Navigation Links and Tabs List */
  .custom-m-nav { flex: 1; overflow-y: auto; }
  .custom-m-menu-list { list-style: none; padding: 0; margin: 0; }
  .custom-m-menu-item { border-bottom: 1px solid #e5e5e5; }
  .custom-m-menu-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 16px 20px;
    background: none;
    border: none;
    text-align: left;
    font-size: 15px;
    font-weight: 600;
    color: #333;
    text-decoration: none;
    cursor: pointer;
  }
  .arrow-forward { color: #888; font-size: 14px; }
  .shop-all-link { color: #002d62; font-style: italic; }

  /* Submenus Sliding Panels Layer 2 */
  .custom-m-submenu-panel {
    position: absolute;
    top: 110px; /* Engine bar ke niche se shuru hoga */
    left: 100%;
    width: 100%;
    height: calc(100% - 110px);
    background: #fff;
    transition: left 0.3s ease-in-out;
    overflow-y: auto;
    z-index: 2;
  }
  .custom-m-submenu-panel.is-active {
    left: 0;
  }
  .custom-m-back-btn {
    width: 100%;
    padding: 12px 15px;
    background: #f9f9f9;
    border: none;
    border-bottom: 1px solid #e5e5e5;
    text-align: left;
    font-size: 14px;
    font-weight: bold;
    color: #555;
    cursor: pointer;
  }
  .custom-m-submenu-title { padding: 15px 20px 5px 20px; margin: 0; font-size: 18px; color: #002d62; }

  /* Engine Popup Modal Styling */
  .engine-popup-modal {
    display: none;
    position: fixed;
    z-index: 999999;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0,0,0,0.6);
    backdrop-filter: blur(3px);
  }
  .engine-popup-content {
    background-color: #fff;
    margin: 15% auto;
    padding: 25px;
    width: 85%;
    max-width: 420px;
    border-radius: 6px;
    position: relative;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }
  .close-popup { position: absolute; right: 15px; top: 10px; color: #555; font-size: 28px; font-weight: bold; cursor: pointer; }
  .engine-popup-content h3 { text-align: center; margin-top: 0; margin-bottom: 20px; color: #002d62; font-size: 18px; }
  .form-group { margin-bottom: 15px; }
  .form-group select { width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 4px; font-size: 14px; }
  .engine-search-submit { width: 100%; padding: 12px; background: #ffcc00; color: #000; border: none; font-weight: bold; cursor: pointer; text-transform: uppercase; border-radius: 4px; }

  /* Mobile Screens Toggle Trigger display */
  @media screen and (max-width: 990px) {
    .custom-hamburger-trigger { display: flex; }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    // Drawer Panel Logic
    var drawer = document.getElementById("customMobileDrawer");
    var openBtn = document.getElementById("openMobileDrawer");
    var closeBtn = document.getElementById("closeMobileDrawer");

    if(openBtn && drawer) {
      openBtn.addEventListener("click", function() {
        drawer.classList.add("is-open");
        document.body.style.overflow = "hidden"; // Page scroll stop karne k liye
      });
    }

    if(closeBtn && drawer) {
      closeBtn.addEventListener("click", function() {
        drawer.classList.remove("is-open");
        document.body.style.overflow = "";
        // Saare active submenus bhi reset kardo back to layer 1
        document.querySelectorAll('.custom-m-submenu-panel').forEach(function(panel) {
          panel.classList.remove('is-active');
        });
      });
    }

    // Submenu Sliding Tabs Logic (Click on link -> Layer 2 Open)
    var menuTriggers = document.querySelectorAll(".custom-m-menu-link.has-children");
    menuTriggers.forEach(function(trigger) {
      trigger.addEventListener("click", function() {
        var targetId = this.getAttribute("data-target");
        var targetPanel = document.getElementById(targetId);
        if(targetPanel) {
          targetPanel.classList.add("is-active");
        }
      });
    });

    // Back Buttons Logic (Layer 2 -> Layer 1)
    var backButtons = document.querySelectorAll(".custom-m-back-btn");
    backButtons.forEach(function(btn) {
      btn.addEventListener("click", function() {
        this.parentElement.classList.remove("is-active");
      });
    });

    // Shop by Engine Popup Modal Logic inside Drawer
    var modal = document.getElementById("enginePopupModal");
    var engineBtn = document.getElementById("openEnginePopup");
    var closePopup = document.querySelector(".close-popup");

    if(engineBtn && modal) {
      engineBtn.addEventListener("click", function() {
        modal.style.display = "block";
      });
    }
    if(closePopup && modal) {
      closePopup.addEventListener("click", function() {
        modal.style.display = "none";
      });
    }
    window.addEventListener("click", function(e) {
      if (e.target == modal) {
        modal.style.display = "none";
      }
    });
  });
</script> {% endcomment %}