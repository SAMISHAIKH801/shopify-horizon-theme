    "custom_liquid_yEgnnW": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<div class=\"maintenance-banner-section\">\n  <div class=\"maintenance-container\">\n    <div class=\"maintenance-banner-wrapper\">\n      \n      <h2 class=\"maintenance-banner-title\">\n        * Treat Yourself & <span class=\"white-text\">Your Wallet</span> *\n      </h2>\n      \n      <div class=\"maintenance-image-container\">\n        <img \n          src=\"https://cdn.shopify.com/s/files/1/0834/9207/7812/files/ME-DESKTOP_0ba5bc2a-04ba-4d32-a6c1-0725cffcf2ef.webp?v=1781601149\" \n          alt=\"Maintenance Essentials Filters\" \n          class=\"maintenance-main-img\"\n          loading=\"lazy\"\n        >\n      </div>\n      \n      <div class=\"maintenance-banner-content\">\n        <a href=\"/collections/all\" class=\"maintenance-btn\">\n          SHOP MAINTENANCE ESSENTIALS\n        </a>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<style>\n  /* Loading Custom OTF Font directly from your Shopify CDN */\n  @font-face {\n    font-family: 'CustomBlackFont';\n    src: url('https://cdn.shopify.com/s/files/1/0834/9207/7812/files/black.otf?v=1781602199') format('opentype');\n    font-weight: 500;\n    font-style: normal;\n    font-display: swap;\n  }\n\n  /* Base Section Wrapper */\n  .maintenance-banner-section {\n    width: 100%;\n    background-color: #001e3d; /* Signature dark blue background */\n    padding: 60px 0;\n    box-sizing: border-box;\n  }\n\n  /* Centered Container locked to maximum 1200px desktop grid width */\n  .maintenance-container {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 0 20px;\n    box-sizing: border-box;\n  }\n\n  .maintenance-banner-wrapper {\n    width: 100%;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    text-align: center;\n  }\n\n  /* Title Style Requirements with Custom Font */\n  .maintenance-banner-title {\n    font-family: 'CustomBlackFont', 'Arial Black', sans-serif;\n    font-size: 40px;\n    font-weight: 500;\n    line-height: 1.2;\n    color: rgb(246, 183, 25); /* Default brand yellow */\n    margin: 0 0 25px 0;\n    text-transform: uppercase;\n    letter-spacing: -0.01em;\n    width: 100%;\n    word-wrap: break-word;\n  }\n\n  /* Target specific text to be white */\n  .maintenance-banner-title .white-text {\n    color: #ffffff !important;\n  }\n\n  /* Image Layout Container */\n  .maintenance-image-container {\n    width: 100%;\n    max-width: 720px; \n    margin: 0 auto 30px auto;\n    display: block;\n  }\n\n  .maintenance-main-img {\n    width: 100%;\n    height: auto;\n    display: block;\n    object-fit: contain;\n  }\n\n  /* Button Positioning Wrapper */\n  .maintenance-banner-content {\n    width: 100%;\n    display: flex;\n    justify-content: center;\n  }\n\n  /* Premium Responsive Yellow Button */\n  .maintenance-btn {\n    display: inline-block;\n    background-color: #e5b122; /* Premium brand yellow */\n    color: #001e3d;\n    font-family: inherit;\n    font-weight: 700;\n    font-size: 15px;\n    letter-spacing: 0.05em;\n    padding: 15px 40px;\n    text-decoration: none;\n    text-transform: uppercase;\n    border: none;\n    transition: transform 0.2s cubic-bezier(0.25, 1, 0.5, 1), background-color 0.2s ease;\n    cursor: pointer;\n    box-shadow: 0px 4px 15px rgba(0, 0, 0, 0.25);\n    white-space: nowrap;\n    box-sizing: border-box;\n  }\n\n  /* Hover micro-interactions */\n  .maintenance-btn:hover {\n    background-color: #f0be33;\n    transform: translateY(-2px);\n  }\n\n  /* Perfect Responsive Media Queries (Mobile & Tablet) */\n  @media (max-width: 991px) {\n    .maintenance-banner-section {\n      padding: 45px 0;\n    }\n    .maintenance-banner-title {\n      font-size: 36px;\n      margin-bottom: 20px;\n    }\n  }\n\n  @media (max-width: 767px) {\n    .maintenance-banner-section {\n      padding: 35px 15px;\n    }\n    .maintenance-banner-title {\n      font-size: 24px; /* Fully responsive size for mobile displays */\n      line-height: 1.3;\n   